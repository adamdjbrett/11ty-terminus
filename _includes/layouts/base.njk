<!doctype html>
<html lang="{{ site.language }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% set pageTitle = title + " | " + site.title if title else site.title %}
  {% set pageDescription = description or site.description %}
  {% set enableCopyButton = copyButton if copyButton is defined else (site.copyButton or false) %}
  {% set enableKatex = katex if katex is defined else (site.katex or false) %}
  <title>{{ pageTitle }}</title>

  <link rel="preload" href="/fonts/FiraCode-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous">
  <link rel="preload" href="/fonts/FiraCode-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous">
  <link rel="stylesheet" href="/css/style.css">

  {% if site.favicon %}
  <link rel="icon" href="{{ site.favicon }}">
  {% elif site.faviconEmoji %}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>{{ site.faviconEmoji }}</text></svg>">
  {% endif %}

  <link rel="canonical" href="{{ page.url | absoluteUrl(site.url) }}">
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="/feed/feed.xml">

  <meta name="description" content="{{ description or site.description }}">
  <meta name="robots" content="{{ robots or 'index, follow' }}">
  <meta name="generator" content="{{ eleventy.generator }}">
  {% if site.fediverseCreator %}
  <meta name="fediverse:creator" content="{{ site.fediverseCreator }}">
  {% endif %}
  <meta name="theme-color" content="#211f1a">
  <meta name="color-scheme" content="dark">

  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page.url | absoluteUrl(site.url) }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:site_name" content="{{ site.title }}">

  {% if site.closeResponsiveMenuOnResize %}
  <script src="/js/auto-close-popover-on-resize.js" defer></script>
  {% endif %}
  {% if enableCopyButton %}
  <script src="/js/copy-code-to-clipboard.js" defer></script>
  {% endif %}
  {% if site.colorSchemeSwitcher %}
  <script src="/js/theme-switcher.js" defer></script>
  {% endif %}
  {% if enableKatex %}
  <link rel="stylesheet" href="/css/katex.min.css">
  <script src="/js/katex.min.js" defer></script>
  {% endif %}
</head>
<body class="layout-{{ site.layout }}" data-theme="{{ site.colorScheme }}">
  <header class="header">
    {% include "partials/header.njk" %}
  </header>
  <main id="main">
    {{ content | safe }}
  </main>
  <footer class="footer">
    {% include "partials/footer.njk" %}
  </footer>
</body>
</html>
