---
layout: layouts/base.njk
title: Archive
permalink: /archive/
---
<h1>Archive</h1>

<ul class="taxonomy-list">
  {% for post in collections.posts %}
  <li>
    <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dotDate }}</time>
    <span aria-hidden="true">::</span>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
  </li>
  {% endfor %}
</ul>
