{
  "name": "terminus-11ty-port",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && rm -rf _site && eleventy --config=eleventy.config.js && pagefind --site _site --glob \"**/*.html\"",
    "start": "npm run build:css && eleventy --serve --config=eleventy.config.js --incremental",
    "build:css": "node scripts/build-css.mjs",
    "deploy": "npm run build && xmit terminus.xmit.dev _site"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11.14.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.8",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@xmit.co/xmit": "0.5.2-0",
    "luxon": "^3.5.0",
    "pagefind": "^1.3.0",
    "sass": "^1.86.3"
  },
  "packageManager": "npm@11.14.0"
}
